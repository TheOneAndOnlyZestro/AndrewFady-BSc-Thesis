@misc{huSpatialtemporalFusionConvolutional2018,
  title = {Spatial-Temporal {{Fusion Convolutional Neural Network}} for {{Simulated Driving Behavior Recognition}}},
  author = {Hu, Yaocong and Lu, MingQi and Lu, Xiaobo},
  year = 2018,
  month = dec,
  number = {arXiv:1812.00615},
  eprint = {1812.00615},
  primaryclass = {cs.CV},
